rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // PHASE 2 - CLAIMS-BASED AUTHORIZATION (NEW)
    // ============================================================================
    
    function hasTenantRole(tid, roles) {
      return roles[tid] != null;
    }
    function roleOf(tid, roles) {
      return roles[tid].role;
    }

    match /tenants/{tenantId} {
      // Allow authenticated users with proper roles
      allow read: if request.auth != null && (isHRX() || hasTenantRole(tenantId, request.auth.token.roles) || isAssignedToTenant(tenantId));
      // Allow unauthenticated reads (needed for public job board to access job_postings subcollection)
      allow read: if true;
      allow write: if request.auth != null && isTenantAdmin(tenantId);

      match /job_orders/{doc} {
        // Allow authenticated users with proper roles
        allow read: if request.auth != null && (isHRX() || hasTenantRole(tenantId, request.auth.token.roles));
        // Allow unauthenticated reads for public job board (to load gig job orders)
        // Client-side filtering will handle visibility
        allow read: if true;
        allow create, update, delete: if request.auth != null && isTenantAdmin(tenantId);
        
        // Shifts subcollection
        match /shifts/{shiftId} {
          allow read: if request.auth != null && (isHRX() || hasTenantRole(tenantId, request.auth.token.roles));
          allow create, update, delete: if request.auth != null && (isTenantAdmin(tenantId) || (request.auth.token.roles != null && tenantId in request.auth.token.roles && request.auth.token.roles[tenantId].role in ['Recruiter', 'Manager']));
          // Allow public read for job board display
          allow read: if true;
        }
      }

      match /applications/{doc} {
        // Temporarily allow all authenticated users to read (TODO: fix custom claims to include tenantId)
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && (isTenantAdmin(tenantId) || (request.auth.token.roles != null && tenantId in request.auth.token.roles && request.auth.token.roles[tenantId].role in ['Recruiter','Manager']));
        // Allow applicants to create/update their own applications
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      }

      match /applicationDrafts/{doc} {
        allow read: if request.auth != null && (isHRX() || hasTenantRole(tenantId, request.auth.token.roles));
        allow create, update, delete: if request.auth != null && (isTenantAdmin(tenantId) || (request.auth.token.roles != null && tenantId in request.auth.token.roles && request.auth.token.roles[tenantId].role in ['Recruiter','Manager']));
        // Allow applicants to create/update/delete their own drafts
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }

      match /userGroups/{doc} {
        allow read: if request.auth != null && (isHRX() || hasTenantRole(tenantId, request.auth.token.roles));
        allow write: if request.auth != null && (isTenantAdmin(tenantId) || (request.auth.token.roles != null && tenantId in request.auth.token.roles && request.auth.token.roles[tenantId].role == 'Recruiter'));
        // Allow users to add themselves to memberIds array (for auto-add on application)
        // Check that only memberIds and updatedAt are being modified
        allow update: if request.auth != null && 
                         request.resource.data.keys().hasOnly(['memberIds', 'updatedAt', 'title', 'description', 'createdAt', 'createdBy', 'tenantId']) &&
                         request.resource.data.memberIds is list && 
                         request.auth.uid in request.resource.data.memberIds;
      }
      
      match /job_postings/{doc} {
        // Allow anyone to read job postings (client-side filtering handles visibility)
        // This is necessary for public job board to work when not logged in
        allow read: if true;
        // Only admins and recruiters can write
        allow write: if request.auth != null && (isTenantAdmin(tenantId) || (request.auth.token.roles != null && tenantId in request.auth.token.roles && request.auth.token.roles[tenantId].role in ['Recruiter', 'Manager']));
      }
      
      // Assignments subcollection - BULLETPROOF RULES
      match /assignments/{assignmentId} {
        // READ Rules: Worker can read own assignments, tenant members can read all tenant assignments
        allow read: if request.auth != null && (
          // Worker can read their own assignments
          resource.data.userId == request.auth.uid ||
          resource.data.candidateId == request.auth.uid ||
          // HRX can read all assignments
          isHRX() ||
          // Users with role in this tenant can read assignments
          hasTenantRole(tenantId, request.auth.token.roles)
        );
        
        // CREATE Rules: Only recruiters/managers/admins can create assignments
        allow create: if request.auth != null && (
          isHRX() ||
          (request.auth.token.roles != null && 
           tenantId in request.auth.token.roles && 
           request.auth.token.roles[tenantId].role in ['Recruiter', 'Manager', 'Admin'])
        ) &&
        // Validate tenantId matches path
        request.resource.data.tenantId == tenantId &&
        // Validate required denormalized fields exist
        request.resource.data.userId != null &&
        request.resource.data.candidateId != null &&
        request.resource.data.firstName != null &&
        request.resource.data.lastName != null &&
        request.resource.data.companyId != null &&
        request.resource.data.companyName != null &&
        request.resource.data.locationId != null &&
        (request.resource.data.locationNickname != null || request.resource.data.worksiteName != null) &&
        request.resource.data.latitude != null &&
        request.resource.data.longitude != null &&
        request.resource.data.jobOrderType != null &&
        request.resource.data.status != null &&
        request.resource.data.startDate != null &&
        request.resource.data.payRate != null &&
        request.resource.data.timesheetMode != null &&
        request.resource.data.createdBy != null &&
        request.resource.data.createdAt != null;
        
        // UPDATE Rules: Recruiters/managers/admins can update, workers can only update own status when active
        allow update: if request.auth != null && (
          // Recruiters/Managers/Admins can update anything
          isHRX() ||
          (request.auth.token.roles != null && 
           tenantId in request.auth.token.roles && 
           request.auth.token.roles[tenantId].role in ['Recruiter', 'Manager', 'Admin']) ||
          // Workers can only update status and notes on their own assignments when active
          (resource.data.userId == request.auth.uid &&
           resource.data.status == 'active' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'notes', 'updatedAt', 'updatedBy']))
        ) &&
        // Always enforce tenantId cannot be changed
        request.resource.data.tenantId == resource.data.tenantId;
        
        // DELETE Rules: Only admins can delete assignments
        allow delete: if request.auth != null && (
          isHRX() ||
          (request.auth.token.roles != null && 
           tenantId in request.auth.token.roles && 
           request.auth.token.roles[tenantId].role == 'Admin')
        );
      }
    }

    // ============================================================================
    // LEGACY RULES (TO BE REMOVED AFTER MIGRATION)
    // ============================================================================
    
    // --- USERS ---
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read, write: if isHRX();
      allow read: if isAuthenticated() && isAssignedToTenant(resource.data.tenantId);
      allow read: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      // Allow users to read other users who belong to the same tenant (for salespeople functionality)
      allow read: if isAuthenticated() && hasCRMAccess() && belongsToSameTenant(resource.data);
      // Allow high-security-level users to update user profiles
      allow write: if isAuthenticated() && isHighSecurityLevel();
      // Unified Association Service access for salespeople
      allow read: if isAuthenticated() && request.auth.uid != null;
      
      // --- USER FOLLOWED COMPANIES ---
      match /followedCompanies/{companyId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
      
      // --- USER SUBCOLLECTIONS ---
      match /notes/{noteId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
        allow read, write: if isHRX();
        allow read, write: if isTenantAdmin(resource.data.tenantId);
      }
      
      match /moments/{momentId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
        allow read, write: if isHRX();
        allow read, write: if isTenantAdmin(resource.data.tenantId);
      }
      
      match /feedback/{feedbackId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
        allow read, write: if isHRX();
        allow read, write: if isTenantAdmin(resource.data.tenantId);
      }
      
      match /selfImprovement/{improvementId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
        allow read, write: if isHRX();
        allow read, write: if isTenantAdmin(resource.data.tenantId);
      }
      
      match /activityLogs/{logId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
        allow read, write: if isHRX();
        allow read, write: if isTenantAdmin(resource.data.tenantId);
      }
    }

    // --- TENANTS (Unified Agencies and Customers) ---
    match /tenants/{tenantId} {
      allow read, write: if isHRX();
      allow read: if isAssignedToTenant(tenantId);
      allow create: if isHRX() && validateTenantSlug();
      allow update: if isHRX() && (resource.data.slug == request.resource.data.slug || validateTenantSlug());

      // --- DIVISIONS (Tenants) ---
      match /divisions/{divisionId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
      }

      // --- REGIONS (Tenants) ---
      match /regions/{regionId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
      }

      // --- DIVISION TYPES (Tenants) ---
      match /divisionTypes/{divisionTypeId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
      }

      // --- CUSTOMERS (Subcollection for tenants that have customers) ---
      match /customers/{customerId} {
        allow read, write: if isHRX();
        allow read: if isAssignedToTenant(tenantId);
        
        // --- LOCATIONS (Customer Locations) ---
        match /locations/{locationId} {
          allow read, write: if isHRX();
          allow read: if isAssignedToTenant(tenantId);
        }
        
        // --- DEPARTMENTS (Customer Departments) ---
        match /departments/{departmentId} {
          allow read, write: if isHRX() || isTenantAdmin(tenantId);
        }
        
        // --- AI SETTINGS (Customer AI Settings) ---
        match /aiSettings/{settingName} {
          allow read, write: if isHRX();
          allow read, write: if isTenantAdmin(tenantId);
        }
        
        // --- AI TRAINING (Customer AI Training) ---
        match /aiTraining/{trainingId} {
          allow read, write: if isHRX();
          allow read, write: if isTenantAdmin(tenantId);
        }

      }

      // --- EMAIL LOGS (Tenant-level Email History) ---
      // Emails are stored at tenants/{tenantId}/email_logs/{emailId}
      match /email_logs/{emailId} {
        allow read, write: if isHRX();
        allow read, write: if isTenantAdmin(tenantId);
        // Allow any authenticated user assigned to this tenant (read-only typically)
        allow read, write: if isAuthenticated() && isAssignedToTenant(tenantId);
      }

      // --- AI CHAT THREADS (Tenant-level) ---
      // Conversations stored at tenants/{tenantId}/ai_chats/{threadId}/messages/{messageId}
      match /ai_chats/{threadId} {
        allow read, write: if isAuthenticated() && isAssignedToTenant(tenantId);
        match /messages/{messageId} {
          allow read, write: if isAuthenticated() && isAssignedToTenant(tenantId);
        }
      }

      // --- CONTACTS (Customer Contacts) ---
      match /contacts/{contactId} {
        allow read, write: if isHRX();
        allow read, write: if isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
      }

      // --- CONTACTS (Tenants) ---
      match /contacts/{contactId} {
        allow read, write: if isHRX();
      }

      // --- LOCATIONS (Tenants) ---
      match /locations/{locationId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
        // Allow unauthenticated reads for public job board (to fetch worksite location data)
        allow read: if true;
      }

      // --- COMPANY LOCATIONS MIRROR (for fast state queries) ---
      match /company_locations/{docId} {
        // Read access for users in this tenant (CRM UI)
        allow read: if isAssignedToTenant(tenantId);
        // Writes come from Cloud Functions using Admin SDK
        allow write: if false;
      }
      
      // --- DEPARTMENTS (Tenants) ---
      match /departments/{departmentId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- WORKFORCE (Tenants) ---
      match /workforce/{workerId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- AI SETTINGS (Tenants) ---
      match /aiSettings/{settingName} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
      }
      
      // --- MODULES (Tenants) ---
      match /modules/{moduleId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        
        // --- HRX-FLEX MODULE SUBCOLLECTIONS ---
        match /jobTitles/{jobTitleId} {
          allow read, write: if isHRX() || isTenantAdmin(tenantId);
        }
        
        match /uniformDefaults/{uniformId} {
          allow read, write: if isHRX() || isTenantAdmin(tenantId);
        }
        
        match /positions/{positionId} {
          allow read, write: if isHRX() || isTenantAdmin(tenantId);
        }
        
        // --- CATCH-ALL FOR HRX-FLEX SUBCOLLECTIONS ---
        match /{subcollection}/{documentId} {
          allow read, write: if isHRX() || isTenantAdmin(tenantId);
        }
      }
      
      // --- AI TRAINING (Tenants) ---
      match /aiTraining/{trainingId} {
        allow read, write: if isHRX();
        allow read, write: if isTenantAdmin(tenantId);
      }

      // --- INTEGRATIONS (Tenants) ---
      match /integrations/{integrationId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
      }

      // --- USER GROUPS (Tenants) ---
      match /userGroups/{groupId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
      }

      // --- USERS (Tenants) ---
      match /users/{userId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
      }

      // --- SETTINGS (Tenants) ---
      match /settings/{settingsId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- SLACK CHANNEL MEMBERSHIPS (Tenants) ---
      match /slackChannelMembers/{membershipId} {
        // Allow authenticated users assigned to tenant to read memberships
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId);
        
        // Allow users to create their own membership (join channel)
        allow create: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         request.resource.data.userId == request.auth.uid &&
                         request.resource.data.channelId != null &&
                         request.resource.data.tenantId == tenantId;
        
        // Allow users to update their own membership (if needed in future)
        allow update: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         resource.data.userId == request.auth.uid &&
                         request.resource.data.userId == request.auth.uid;
        
        // Allow users to delete their own membership (leave channel)
        allow delete: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         resource.data.userId == request.auth.uid;
        
        // Allow admins to manage all memberships
        allow write: if isHRX() || isTenantAdmin(tenantId);
      }
      
      // --- SLACK CHANNELS (Tenants) ---
      match /slackChannels/{channelId} {
        // Allow authenticated users assigned to tenant to read channels
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId);
        
        // Allow users to update channel status (mute/unmute, watch/unwatch)
        allow update: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                         (request.resource.data.status == 'watching' || 
                          request.resource.data.status == 'unlinked' || 
                          request.resource.data.status == 'muted');
        
        // Allow admins to delete channels
        allow delete: if isHRX() || isTenantAdmin(tenantId);
        
        // Create is backend-only
        allow create: if false;
      }

      // --- FEED POSTS (Dashboard Post Composer) ---
      match /feed_posts/{postId} {
        // Allow authenticated tenant members to read posts
        allow read: if isAuthenticated() && (
          isAssignedToTenant(tenantId) ||
          (request.auth.token.roles != null && tenantId in request.auth.token.roles) ||
          isHRX()
        );
        
        // Allow authenticated tenant members to create posts (author must match auth.uid)
        allow create: if isAuthenticated() && 
                         request.resource.data.authorId == request.auth.uid &&
                         request.resource.data.tenantId == tenantId &&
                         (
                           isAssignedToTenant(tenantId) ||
                           (request.auth.token.roles != null && tenantId in request.auth.token.roles) ||
                           isHRX()
                         );
        
        // Allow authors to update their own posts (with reasonable restrictions)
        allow update: if isAuthenticated() && 
                         resource.data.authorId == request.auth.uid &&
                         request.resource.data.tenantId == resource.data.tenantId &&
                         request.resource.data.authorId == resource.data.authorId &&
                         request.resource.data.createdAt == resource.data.createdAt &&
                         (
                           isAssignedToTenant(tenantId) ||
                           (request.auth.token.roles != null && tenantId in request.auth.token.roles) ||
                           isHRX()
                         );
        
        // Only admins can delete posts
        allow delete: if isAuthenticated() && (isHRX() || isTenantAdmin(tenantId));
      }

      // --- MENTIONS INDEX (For quick mention queries) ---
      match /mentions_index/{mentionRefId} {
        // Allow authenticated tenant members to read mentions index
        allow read: if isAuthenticated() && (
          isAssignedToTenant(tenantId) ||
          (request.auth.token.roles != null && tenantId in request.auth.token.roles) ||
          isHRX()
        );
        
        // Only backend (Cloud Functions) can write mentions index
        allow write: if isHRX();
      }
      
      // --- DM THREADS (Tenants) ---
      match /dmThreads/{threadId} {
        // Allow authenticated users to read threads where they are a participant
        allow read: if isAuthenticated() && 
                       isAssignedToTenant(tenantId) &&
                       request.auth.uid in resource.data.participantIds;
        
        // Allow authenticated users to create threads where they are a participant
        allow create: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         request.auth.uid in request.resource.data.participantIds;
        
        // Allow users to update threads where they are a participant
        allow update: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         request.auth.uid in resource.data.participantIds;
        
        // Allow admins to manage all threads
        allow write: if isHRX() || isTenantAdmin(tenantId);
        
        // DM Messages subcollection
        match /messages/{messageId} {
          // Allow authenticated users to read messages in threads where they are a participant
          allow read: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)/dmThreads/$(threadId)).data.participantIds;
          
          // Allow authenticated users to create messages in threads where they are a participant
          allow create: if isAuthenticated() && 
                           isAssignedToTenant(tenantId) &&
                           request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)/dmThreads/$(threadId)).data.participantIds &&
                           request.resource.data.senderId == request.auth.uid;
          
          // Allow users to update their own messages
          allow update: if isAuthenticated() && 
                           isAssignedToTenant(tenantId) &&
                           resource.data.senderId == request.auth.uid;
          
          // Allow admins to manage all messages
          allow write: if isHRX() || isTenantAdmin(tenantId);
        }
      }
      
      // --- DM TYPING INDICATORS (Tenants) ---
      match /dmTyping/{typingId} {
        // Helper: Check if user is a participant in the thread (for read)
        function isThreadParticipantForTyping() {
          let threadId = resource.data.threadId;
          let thread = get(/databases/$(database)/documents/tenants/$(tenantId)/dmThreads/$(threadId)).data;
          return thread != null && 
                 thread.participantIds != null && 
                 thread.participantIds is list &&
                 request.auth.uid in thread.participantIds;
        }
        
        // Helper: Check if user is a participant in the thread (for create)
        function isThreadParticipantForTypingCreate() {
          let threadId = request.resource.data.threadId;
          let thread = get(/databases/$(database)/documents/tenants/$(tenantId)/dmThreads/$(threadId)).data;
          return thread != null && 
                 thread.participantIds != null && 
                 thread.participantIds is list &&
                 request.auth.uid in thread.participantIds;
        }
        
        // Read: User must be a participant in the thread
        allow read: if isAuthenticated() && 
                      isAssignedToTenant(tenantId) && 
                      isThreadParticipantForTyping();
        
        // Create: User must be a participant and can only create their own typing indicator
        allow create: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) && 
                         isThreadParticipantForTypingCreate() &&
                         request.resource.data.userId == request.auth.uid &&
                         request.resource.data.threadId != null;
        
        // Update: User can only update their own typing indicator
        allow update: if isAuthenticated() && 
                        isAssignedToTenant(tenantId) && 
                        isThreadParticipantForTyping() &&
                        resource.data.userId == request.auth.uid &&
                        request.resource.data.userId == request.auth.uid &&
                        request.resource.data.threadId == resource.data.threadId;
        
        // Delete: User can only delete their own typing indicator
        allow delete: if isAuthenticated() && 
                        isAssignedToTenant(tenantId) && 
                        isThreadParticipantForTyping() &&
                        resource.data.userId == request.auth.uid;
        
        // Allow admins to manage all typing indicators
        allow write: if isHRX() || isTenantAdmin(tenantId);
      }
      
      // --- INTERNAL DMs (Tenants) - for unread count listening ---
      match /internalDMs/{dmId} {
        // Allow authenticated users to read DMs where they are a participant
        allow read: if isAuthenticated() && 
                       isAssignedToTenant(tenantId) &&
                       (request.auth.uid in resource.data.participants || 
                        resource.data.participants == null);
        
        // Allow authenticated users to create DMs where they are a participant
        allow create: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         (request.auth.uid in request.resource.data.participants ||
                          request.resource.data.participants == null);
        
        // Allow users to update DMs where they are a participant (for unread counts, etc.)
        allow update: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         (request.auth.uid in resource.data.participants ||
                          resource.data.participants == null);
        
        // Allow admins to manage all DMs
        allow write: if isHRX() || isTenantAdmin(tenantId);
      }
      
      // --- INTERNAL CHANNELS (Tenants) - for unread count listening ---
      match /internalChannels/{channelId} {
        // Allow authenticated users to read channels where they are a member
        allow read: if isAuthenticated() && 
                       isAssignedToTenant(tenantId) &&
                       (request.auth.uid in resource.data.memberIds ||
                        resource.data.memberIds == null);
        
        // Allow authenticated users to create channels (with proper membership)
        allow create: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         (request.auth.uid in request.resource.data.memberIds ||
                          request.resource.data.memberIds == null);
        
        // Allow users to update channels where they are a member (for unread counts, mute status, etc.)
        allow update: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) &&
                         (request.auth.uid in resource.data.memberIds ||
                          resource.data.memberIds == null);
        
        // Allow admins to manage all channels
        allow write: if isHRX() || isTenantAdmin(tenantId);
      }
      
      // --- SLACK MESSAGES (Tenant Subcollection) ---
      match /slack_messages/{messageId} {
        // Allow authenticated users assigned to tenant to read messages
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId);
        
        // Create/update/delete are backend-only
        allow write: if false;
      }
      
      // --- BRANDING (Tenants) ---
      match /branding/{brandingId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
      }
      
      // --- TENANTS (Subcollection for customer references) ---
      match /tenants/{customerId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- JOB ORDERS (Tenants) ---
      match /jobOrders/{jobOrderId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);

        // --- SHIFTS (Job Orders) ---
        match /shifts/{shiftId} {
          allow read, write: if isHRX() || isTenantAdmin(tenantId);
          allow read: if isAssignedToTenant(tenantId);
        }
      }
      
      // --- RECRUITER MODULE COLLECTIONS ---
      
      // --- RECRUITER CLIENTS (Extensions of CRM Companies) ---
      match /recruiter_clients/{crmCompanyId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- RECRUITER JOB ORDERS ---
      match /recruiter_jobOrders/{jobOrderId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- RECRUITER CANDIDATES ---
      match /recruiter_candidates/{candidateId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- RECRUITER APPLICATIONS ---
      match /recruiter_applications/{applicationId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- RECRUITER SUBMITTALS ---
      match /recruiter_submittals/{submittalId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- RECRUITER INTERVIEWS ---
      match /recruiter_interviews/{interviewId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- RECRUITER OFFERS ---
      match /recruiter_offers/{offerId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- RECRUITER PLACEMENTS ---
      match /recruiter_placements/{placementId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- RECRUITER WORKSITES ---
      match /recruiter_worksites/{worksiteId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- RECRUITER JOBS BOARD POSTS ---
      match /recruiter_jobsBoardPosts/{postId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
        // Allow public read access for job board posts
        allow read: if resource.data.visibility == 'public';
      }
      
      // --- RECRUITER AI SCORES ---
      match /recruiter_aiScores/{scoreId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- RECRUITER AUDIT LOGS ---
      match /recruiter_auditLogs/{logId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      // --- CRM COLLECTIONS (Tenants) ---
      match /crm_contacts/{contactId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId); // For activity logging
        allow read: if isAuthenticated() && isHighSecurityLevel(); // Admin override
        // Temporary: Allow all authenticated users for debugging
        allow read: if isAuthenticated();
        // Unified Association Service access
        allow read: if isAuthenticated() && request.auth.uid != null;

        // Prevent direct writes to associations arrays; must go through callable
        allow update: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess() &&
          !(request.resource.data.diff(resource.data).changedKeys().hasAny(['associations']) ||
            request.resource.data.keys().hasAny(['associations']));
      }
      
      match /crm_companies/{companyId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId); // For activity logging
        allow read: if isAuthenticated() && isHighSecurityLevel(); // Admin override
        // Temporary: Allow all authenticated users for debugging
        allow read: if isAuthenticated();
        // Unified Association Service access
        allow read: if isAuthenticated() && request.auth.uid != null;

        // Prevent direct writes to associations arrays; must go through callable
        allow update: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess() &&
          !(request.resource.data.diff(resource.data).changedKeys().hasAny(['associations']) ||
            request.resource.data.keys().hasAny(['associations']));
        
        // --- COMPANY LOCATIONS ---
        match /locations/{locationId} {
          allow read, write: if isHRX() || isTenantAdmin(tenantId);
          allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
          allow read: if isAssignedToTenant(tenantId);
          // Allow all authenticated users to read locations for association service
          allow read: if isAuthenticated() && request.auth.uid != null;
        }
        
        // --- COMPANY DIVISIONS ---
        match /divisions/{divisionId} {
          allow read, write: if isHRX() || isTenantAdmin(tenantId);
          allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
          allow read: if isAssignedToTenant(tenantId);
        }
        
        // --- COMPANY NEWS ARTICLES ---
        match /newsArticles/{articleId} {
          allow read, write: if isHRX() || isTenantAdmin(tenantId);
          allow read: if isAssignedToTenant(tenantId);
          allow read: if isAuthenticated(); // Temporary for testing
        }
      }
      
      match /crm_deals/{dealId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        // Allow updating fields except associations directly (enforce callable for associations)
        allow update: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess() &&
          !(request.resource.data.diff(resource.data).changedKeys().hasAny(['associations']) ||
            request.resource.data.keys().hasAny(['associations']));
        allow read: if isAuthenticated() && isHighSecurityLevel(); // Admin override
        // Temporary: Allow all authenticated users for debugging
        allow read: if isAuthenticated();
        // Unified Association Service access
        allow read: if isAuthenticated() && request.auth.uid != null;
      }
      
      match /crm_pipeline_stages/{stageId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
      }
      
      match /crm_salespeople/{salespersonId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        // Temporary: Allow all authenticated users for debugging
        allow read: if isAuthenticated();
      }
      
      match /crm_tasks/{taskId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        // Prevent direct writes to associations arrays; must go through callable if introduced
        allow update: if isAuthenticated() && (resource.data.assignedTo == request.auth.uid || isTenantAdmin(tenantId)) && (
          !(request.resource.data.diff(resource.data).changedKeys().hasAny(['associations']) ||
            request.resource.data.keys().hasAny(['associations']))
        );
        allow delete: if isAuthenticated() && (resource.data.assignedTo == request.auth.uid || isTenantAdmin(tenantId));
        allow read, write, create, update, delete: if isAuthenticated() && isHighSecurityLevel(); // Admin override
      }
      
      // --- PROSPECTING COLLECTIONS ---
      match /prospecting_runs/{runId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        allow update: if isAuthenticated() && (resource.data.createdByUid == request.auth.uid || isTenantAdmin(tenantId));
        allow delete: if isAuthenticated() && (resource.data.createdByUid == request.auth.uid || isTenantAdmin(tenantId));
        // Allow Cloud Functions to write (they use admin SDK)
        allow write: if false; // Cloud Functions use admin SDK, so they bypass security rules
      }
      
      match /prospecting_saved_searches/{searchId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        allow update: if isAuthenticated() && (resource.data.createdByUid == request.auth.uid || isTenantAdmin(tenantId));
        allow delete: if isAuthenticated() && (resource.data.createdByUid == request.auth.uid || isTenantAdmin(tenantId));
      }
      
      match /email_templates/{templateId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        allow update: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isTenantAdmin(tenantId));
        allow delete: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isTenantAdmin(tenantId));
      }
      
      // Tasks collection (for task management system)
      match /tasks/{taskId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        allow update: if isAuthenticated() && (resource.data.assignedTo == request.auth.uid || isTenantAdmin(tenantId));
        allow delete: if isAuthenticated() && (resource.data.assignedTo == request.auth.uid || isTenantAdmin(tenantId));
        allow read, write, create, update, delete: if isAuthenticated() && isHighSecurityLevel(); // Admin override
      }
      
      // AI Task Suggestions
      match /ai_task_suggestions/{suggestionId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        allow update: if isAuthenticated() && (resource.data.salespersonId == request.auth.uid || isTenantAdmin(tenantId));
        allow delete: if isAuthenticated() && (resource.data.salespersonId == request.auth.uid || isTenantAdmin(tenantId));
      }
      
      // Activity Logs
      match /activityLogs/{logId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow read, write, create, update, delete: if isAuthenticated() && isAssignedToTenant(tenantId);
        allow read, write, create, update, delete: if isAuthenticated() && isHighSecurityLevel();
        // Temporary: Allow all authenticated users for debugging
        allow read, write, create, update, delete: if isAuthenticated();
      }
      
      // --- CRM NOTES COLLECTIONS ---
      match /contact_notes/{noteId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        allow update: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isTenantAdmin(tenantId));
        allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isTenantAdmin(tenantId));
      }
      
      match /company_notes/{noteId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        allow update: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isTenantAdmin(tenantId));
        allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isTenantAdmin(tenantId));
      }
      
      match /deal_notes/{noteId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        allow update: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isTenantAdmin(tenantId));
        allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isTenantAdmin(tenantId));
      }
      
      match /location_notes/{noteId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        allow update: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isTenantAdmin(tenantId));
        allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isTenantAdmin(tenantId));
      }
      
      // 🆕 UNIVERSAL ASSOCIATIONS SYSTEM
      match /crm_associations/{associationId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasCRMAccess();
        allow read: if isAssignedToTenant(tenantId);
        allow create: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
        allow update: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isTenantAdmin(tenantId));
        allow delete: if isAuthenticated() && isAssignedToTenant(tenantId) && hasCRMAccess();
      }
      
      // --- KPI SYSTEM COLLECTIONS ---
      match /kpi_definitions/{kpiId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAssignedToTenant(tenantId);
      }
      
      match /kpi_assignments/{assignmentId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAuthenticated() && request.auth.uid == resource.data.salespersonId;
        allow read: if isAssignedToTenant(tenantId);
      }
      
      match /kpi_tracking/{trackingId} {
        allow read: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAuthenticated() && request.auth.uid == resource.data.salespersonId;
        allow read: if isAssignedToTenant(tenantId);
        allow write: if isAuthenticated() && request.auth.uid == resource.data.salespersonId;
        allow create: if isHRX() || isTenantAdmin(tenantId);
      }
      
      match /kpi_activities/{activityId} {
        allow read: if isHRX() || isTenantAdmin(tenantId);
        allow read: if isAuthenticated() && request.auth.uid == resource.data.salespersonId;
        allow read: if isAssignedToTenant(tenantId);
        allow write: if isAuthenticated() && request.auth.uid == resource.data.salespersonId;
        allow create: if isHRX() || isTenantAdmin(tenantId);
      }
      
      match /kpi_task_suggestions/{suggestionId} {
        allow read, write: if isAuthenticated() && request.auth.uid == resource.data.salespersonId;
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow create: if isHRX() || isTenantAdmin(tenantId);
      }

      // --- SMS OUTBOUND REQUESTS (Tenant Subcollection) ---
      match /smsOutboundRequests/{requestId} {
        // Read: Internal users assigned to tenant
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId) && isInternal(tenantId);
        
        // Create: Internal users can create outbound requests
        allow create: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) && 
                         isInternal(tenantId) &&
                         request.resource.data.tenantId == tenantId &&
                         request.resource.data.status == 'queued';
        
        // Update: Only backend (Cloud Tasks worker) can update requests
        allow update: if false; // Cloud Tasks worker uses Admin SDK
        
        // Delete: Only admins can delete requests
        allow delete: if isHRX() || isTenantAdmin(tenantId);
      }
      
      // --- SMS THREADS (Tenant Subcollection) ---
      match /smsThreads/{threadId} {
        // Read: Internal users (security level >= 5) assigned to tenant
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId) && isInternal(tenantId);
        
        // Create: Internal users can create threads (for outbound messages)
        allow create: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) && 
                         isInternal(tenantId) &&
                         request.resource.data.tenantId == tenantId;
        
        // Update: Internal users can update threads (assignment, status, etc.)
        // But deny client writes to inbound-specific fields (handled by webhook)
        allow update: if isAuthenticated() && 
                         isAssignedToTenant(tenantId) && 
                         isInternal(tenantId) &&
                         request.resource.data.tenantId == resource.data.tenantId &&
                         // Prevent client from writing inbound message fields
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastInboundAt', 'lastInboundMessageSnippet']);
        
        // Delete: Only admins can delete threads
        allow delete: if isHRX() || isTenantAdmin(tenantId);
        
        // Messages subcollection
        match /messages/{messageId} {
          // Read: Internal users assigned to tenant
          allow read: if isAuthenticated() && isAssignedToTenant(tenantId) && isInternal(tenantId);
          
          // Create: Internal users can create outbound messages
          // Inbound messages are created by webhook (Admin SDK), so deny client creates with inbound direction
          allow create: if isAuthenticated() && 
                           isAssignedToTenant(tenantId) && 
                           isInternal(tenantId) &&
                           request.resource.data.tenantId == tenantId &&
                           request.resource.data.threadId == threadId &&
                           // Only allow outbound messages from client
                           request.resource.data.direction == 'outbound';
          
          // Update: Internal users can update their own outbound messages (status, etc.)
          // Deny updates to inbound messages (handled by webhook)
          allow update: if isAuthenticated() && 
                           isAssignedToTenant(tenantId) && 
                           isInternal(tenantId) &&
                           resource.data.direction == 'outbound' &&
                           request.resource.data.tenantId == resource.data.tenantId &&
                           request.resource.data.threadId == resource.data.threadId;
          
          // Delete: Only admins can delete messages
          allow delete: if isHRX() || isTenantAdmin(tenantId);
        }
      }
      
      // --- SMS TEMPLATES (Tenant Subcollection) ---
      match /smsTemplates/{templateId} {
        // Read: Internal users assigned to tenant
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId) && isInternal(tenantId);
        
        // Write: Only admins/managers (security level >= 6) can create/update/delete templates
        allow write: if isHRX() || 
                        (isAuthenticated() && 
                         isAssignedToTenant(tenantId) && 
                         hasSecurityLevel(tenantId, 6) &&
                         request.resource.data.tenantId == tenantId);
      }
      
      // --- SMS CONSENTS (Tenant Subcollection) ---
      match /smsConsents/{userId} {
        // Read: Internal users assigned to tenant (can read consents for their tenant)
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId) && isInternal(tenantId);
        
        // Write: Only admins/managers can update consents (STOP/HELP handled by webhook with Admin SDK)
        // Users can read their own consent
        allow read: if isAuthenticated() && request.auth.uid == userId;
        
        // Write: Only backend (webhook) or admins can write
        allow write: if isHRX() || isTenantAdmin(tenantId);
        
        // Consent events subcollection
        match /events/{eventId} {
          // Read: Internal users assigned to tenant
          allow read: if isAuthenticated() && isAssignedToTenant(tenantId) && isInternal(tenantId);
          
          // Write: Only backend (webhook) can write events
          allow write: if false; // Webhook uses Admin SDK
        }
      }
      
      // --- MESSAGE LOGS (Tenant Subcollection - Unified) ---
      match /messageLogs/{logId} {
        // Read: Internal users assigned to tenant
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId) && isInternal(tenantId);
        
        // Write: Only backend (Cloud Functions) can write logs
        allow write: if false; // Cloud Functions use Admin SDK
      }
      
      // --- MESSAGE TEMPLATES (Tenant Subcollection - Unified Template System) ---
      match /messageTemplates/{templateId} {
        // Read: Internal users assigned to tenant
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId) && isInternal(tenantId);
        
        // Write: Only admins/managers (security level >= 6) can create/update/delete templates
        allow write: if isHRX() || 
                        (isAuthenticated() && 
                         isAssignedToTenant(tenantId) && 
                         hasSecurityLevel(tenantId, 6) &&
                         request.resource.data.tenantId == tenantId);
      }
      
      // --- RECRUITER NUMBERS (Tenant Subcollection) ---
      match /recruiterNumbers/{recruiterId} {
        // Read: Internal users assigned to tenant
        allow read: if isAuthenticated() && isAssignedToTenant(tenantId) && isInternal(tenantId);
        
        // Users can read their own number assignment
        allow read: if isAuthenticated() && request.auth.uid == recruiterId;
        
        // Write: Only admins/managers can assign numbers
        allow write: if isHRX() || 
                        (isAuthenticated() && 
                         isAssignedToTenant(tenantId) && 
                         hasSecurityLevel(tenantId, 6));
      }

      // --- JOB ORDERS (Tenant Subcollection) ---
      match /job_orders/{jobOrderId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
        
        // --- SHIFTS (Job Order Subcollection) ---
        match /shifts/{shiftId} {
          allow read, write: if isHRX() || isTenantAdmin(tenantId);
          allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
          allow read: if isAssignedToTenant(tenantId);
          // Allow public read for job board display
          allow read: if true;
        }
      }

      // --- JOBS BOARD POSTS (Tenant Subcollection) ---
      match /jobs_board_posts/{postId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
        // Allow public read access for job board posts
        allow read: if resource.data.visibility == 'public';
      }

      // --- JOB POSTINGS (New collection name) ---
      match /job_postings/{postId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
        // Allow public read access for job postings (for unauthenticated users)
        // Allow reads for public or restricted posts (client-side will filter restricted by user groups)
        allow read: if resource.data.visibility == 'public' || resource.data.visibility == 'restricted';
      }

      // --- JOB APPLICATIONS (Tenant Subcollection) ---
      match /job_applications/{applicationId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }

      // --- CANDIDATES (Tenant Subcollection) ---
      match /candidates/{candidateId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }

      // --- EMPLOYEES (Tenant Subcollection) ---
      match /employees/{employeeId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
        allow read: if isAssignedToTenant(tenantId);
      }

      // --- COUNTERS (Tenant Subcollection for auto-increment) ---
      match /counters/{counterId} {
        allow read, write: if isHRX() || isTenantAdmin(tenantId);
        allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
      }
    }

    // Context Engine: Only HRX admins can read/write
    match /settings/{docId} {
      allow read, write: if isHRX();
    }
    match /settings/context/{docId} {
      allow read, write: if isHRX();
    }
    match /settings/context/scenarios/{scenarioId} {
      allow read, write: if isHRX();
    }
    match /context_versions/{versionId} {
      allow read, write: if isHRX();
    }
    match /context_audit/{auditId} {
      allow read, write: if isHRX();
    }
    
    // --- ASSIGNMENTS ---
    match /assignments/{assignmentId} {
      // Temporarily allow all authenticated users to read assignments
      // TODO: Tighten this once we verify tenantId is always set on assignments
      allow read: if isAuthenticated();
      allow write: if isHRX() || isTenantAdmin(resource.data.tenantId);
    }
    
    // --- SHIFTS ---
    match /shifts/{shiftId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow read: if isAuthenticated() && isAssignedToTenant(resource.data.tenantId);
    }
    
    // --- JOB ORDERS ---
    match /jobOrders/{jobOrderId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow read: if isAuthenticated() && isAssignedToTenant(resource.data.tenantId);
    }
    
    // --- GLOBAL AI SETTINGS ---
    match /appAiSettings/{documentId} {
      allow read, write: if isHRX();
    }

    // Context Journeys subcollection
    match /appAiSettings/global/contextJourneys/{journeyId} {
      allow read, write: if isHRX();
    }

    // --- FEEDBACK CAMPAIGNS ---
    match /feedbackCampaigns/{campaignId} {
      allow read, write: if isHRX();
    }

    // --- FEEDBACK RESPONSES ---
    match /feedbackResponses/{responseId} {
      allow read, write: if isHRX();
    }

    // --- DASHBOARD FEED (Mentions, etc.) ---
    match /dashboardFeed/{feedItemId} {
      // Users can read their own feed items (primary rule for mentions)
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      // HRX can read any feed items
      allow read: if isHRX();
      // Tenant admins can read feed items for their tenant (if tenantId exists)
      allow read: if isAuthenticated() && 
                     resource.data.tenantId != null &&
                     isTenantAdmin(resource.data.tenantId);
      // Only backend/HRX can write feed items (Cloud Functions create mentions)
      allow write: if isHRX();
    }

    // --- EVENTS (Event Bus) ---
    match /events/{eventId} {
      allow read, write: if isHRX();
      allow read, write: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && isAssignedToTenant(resource.data.tenantId) && hasRecruiterAccess();
      allow read: if isAuthenticated() && isAssignedToTenant(resource.data.tenantId);
    }

    // --- SLACK MESSAGES (Root-level collection) ---
    match /slack_messages/{messageId} {
      // Allow authenticated users to read messages for their active tenant
      allow read: if isAuthenticated() && 
                     resource.data.tenantId != null &&
                     isAssignedToTenant(resource.data.tenantId);
      
      // Write is backend-only (Cloud Functions)
      allow write: if false;
    }

    // --- USER PRESENCE (Root-level collection) ---
    match /userPresence/{userId} {
      // Allow authenticated users to read any user's presence (for status indicators)
      allow read: if isAuthenticated();
      
      // Users can only create/update their own presence document
      allow create: if isAuthenticated() && 
                      request.auth.uid == userId;
      
      allow update: if isAuthenticated() && 
                      request.auth.uid == userId;
      
      // No deletes (presence should be maintained)
      allow delete: if false;
    }

    // --- SLACK MESSAGE REACTIONS (Root-level collection) ---
    match /slackMessageReactions/{reactionId} {
      // Allow authenticated users to read reactions (for displaying in UI)
      allow read: if isAuthenticated();
      
      // Write is handled by Cloud Function (reactToSlackMessage uses admin SDK)
      allow write: if false;
    }

    // --- MOMENT ANALYSIS ---
    match /moment_analysis/{analysisId} {
      allow read, write: if isHRX();
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow read: if isTenantAdmin(resource.data.tenantId);
    }

    // --- FEEDBACK ANALYSIS ---
    match /feedback_analysis/{analysisId} {
      allow read, write: if isHRX();
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow read: if isTenantAdmin(resource.data.tenantId);
    }

    // --- SELF IMPROVEMENT REPORTS ---
    match /selfImprovementReports/{reportId} {
      allow read, write: if isHRX();
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow read: if isTenantAdmin(resource.data.tenantId);
    }

    // --- VECTOR COLLECTIONS ---
    match /vectorCollections/{collectionId} {
      allow read, write: if isHRX();
    }

    // --- CONTEXT ENGINES ---
    match /contextEngines/{engineId} {
      allow read, write: if isHRX();
    }

    // --- CONTEXT SOURCES ---
    match /contextSources/{sourceId} {
      allow read, write: if isHRX();
    }

    // --- RETRIEVAL FILTERS ---
    match /retrievalFilters/{filterId} {
      allow read, write: if isHRX();
    }

    // --- PROMPT TEMPLATES ---
    match /promptTemplates/{templateId} {
      allow read, write: if isHRX();
    }

    // --- AUTODEVOPS LOGS ---
    match /autoDevOpsLogs/{logId} {
      allow read, write: if isHRX();
    }

    // --- AUTODEVOPS SETTINGS ---
    match /autoDevOpsSettings/{settingId} {
      allow read, write: if isHRX();
    }

    // --- AI CHAT MODULE ---
    match /modules/ai-chat {
      allow read, write: if isHRX();
    }

    // --- CONVERSATIONS ---
    match /conversations/{conversationId} {
      allow read, write: if isHRX();
      allow read: if isAuthenticated() && request.auth.uid == resource.data.workerId;
      allow create: if isAuthenticated();
    }

    // --- CHECKINS ---
    match /checkins/{checkinId} {
      allow read, write: if isHRX();
      allow read: if isAuthenticated() && request.auth.uid == resource.data.workerId;
      allow create: if isAuthenticated();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notificationId} {
      allow read, write: if isHRX();
      // TODO: Add tenant specific rules when implementing their notification views
    }

    // Broadcast Module Rules
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null && (
        resource.data.tenantId == request.auth.token.tenantId ||
        request.auth.token.role == 'admin'
      );
      allow create: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'tenant_admin'
      );
      allow update: if request.auth != null && (
        resource.data.senderId == request.auth.uid ||
        request.auth.token.role == 'admin'
      );
      allow delete: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    match /broadcast_notifications/{notificationId} {
      allow read: if request.auth != null && (
        resource.data.recipientId == request.auth.uid ||
        resource.data.tenantId == request.auth.token.tenantId ||
        request.auth.token.role == 'admin'
      );
      allow create: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'tenant_admin'
      );
      allow update: if request.auth != null && (
        resource.data.recipientId == request.auth.uid ||
        request.auth.token.role == 'admin'
      );
    }
    
    match /broadcast_replies/{replyId} {
      allow read: if request.auth != null && (
        resource.data.workerId == request.auth.uid ||
        resource.data.tenantId == request.auth.token.tenantId ||
        request.auth.token.role == 'admin'
      );
      allow create: if request.auth != null && (
        resource.data.workerId == request.auth.uid ||
        request.auth.token.role == 'admin'
      );
      allow update: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    match /broadcast_templates/{templateId} {
      allow read: if request.auth != null && (
        resource.data.tenantId == request.auth.token.tenantId ||
        request.auth.token.role == 'admin'
      );
      allow write: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'tenant_admin'
      );
    }

    // Campaigns Module Rules
    match /campaigns/{campaignId} {
      allow read: if request.auth != null && (
        resource.data.tenantId == request.auth.token.tenantId ||
        resource.data.createdBy == 'HRX' ||
        request.auth.token.role == 'admin'
      );
      allow create: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'tenant_admin'
      );
      allow update: if request.auth != null && (
        resource.data.creatorUserId == request.auth.uid ||
        request.auth.token.role == 'admin'
      );
      allow delete: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        resource.data.creatorUserId == request.auth.uid
      );
    }
    
    match /campaign_responses/{responseId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.tenantId == request.auth.token.tenantId ||
        request.auth.token.role == 'admin'
      );
      allow create: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.role == 'admin'
      );
      allow update: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    match /campaign_schedules/{scheduleId} {
      allow read, write: if request.auth != null && (
        resource.data.tenantId == request.auth.token.tenantId ||
        request.auth.token.role == 'admin'
      );
    }
    
    match /campaign_analysis/{analysisId} {
      allow read, write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // --- JSI (Job Satisfaction Insights) ---
    match /jsiScores/{docId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    match /jsiLogs/{docId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
    }
    match /jsiPrompts/{docId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    match /jsiAlerts/{docId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
    }
    match /jsiRiskFlags/{docId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
    }
    match /jsiSettings/{docId} {
      allow read, write: if isHRX() || isTenantAdmin(docId);
    }
    match /jsiBaselines/{docId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
    }
    match /aiActions/{docId} {
      allow read, write: if isHRX();
    }

    // --- HRX MODULES ---

    // --- RESET MODE ---
    match /resetMode/{resetId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
    }
    match /resetModeTriggers/{triggerId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
    }
    match /resetModeCheckIns/{checkInId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
    }

    // --- MINI-LEARNING BOOSTS ---
    match /learningBoosts/{boostId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && resource.data.isActive == true;
    }
    match /userLearningBoosts/{userBoostId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
    }
    match /userLearningProfiles/{userId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated();
    }

    // --- PROFESSIONAL GROWTH ---
    match /careerGoals/{goalId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
    }
    match /careerJournal/{entryId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
    }
    match /skillsInventory/{userId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated();
    }
    match /growthMetrics/{metricId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // --- WORK-LIFE BALANCE ---
    match /balanceCheckIns/{checkInId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
    }
    match /wellbeingReflections/{reflectionId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
    }
    match /burnoutRiskIndex/{riskId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    match /balanceTrends/{trendId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    match /balanceAlerts/{alertId} {
      allow read, write: if isHRX() || isTenantAdmin(resource.data.tenantId);
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // --- MODULES CONFIGURATION ---
    match /modules/{moduleId} {
      allow read, write: if isHRX();
    }

    // --- MOTIVATIONS (Motivational Quotes) ---
    match /motivations/{motivationId} {
      allow read: if isAuthenticated();
      allow write: if isHRX();
    }

    // --- HELP TOPICS ---
    match /help_topics/{topicId} {
      allow read: if isAuthenticated();
      allow write: if isHRX();
    }

    // --- INVITES ---
    match /invites/{inviteId} {
      allow read, write: if isHRX();
      allow read: if isAuthenticated() && resource.data.email == request.auth.token.email;
    }

    // --- COMPANY NEWS CACHE ---
    match /companyNewsCache/{companyId}/{date} {
      allow read: if isAuthenticated();
      allow write: if false; // Only allow writes from Cloud Functions
    }

    // --- DEFAULT CATCH-ALL ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- LEGACY FUNCTIONS (TO BE REMOVED AFTER MIGRATION) ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Legacy isHRX function - now uses claims
    function isHRX() {
      return isAuthenticated() && (request.auth.token.hrx == true || getUser().role == "HRX");
    }

    function isAssignedToTenant(tenantId) {
      return isAuthenticated() && (
        getUser().tenantIds != null && (
          (getUser().tenantIds is list && getUser().tenantIds.hasAny([tenantId])) ||
          (getUser().tenantIds is map && tenantId in getUser().tenantIds)
        ) ||
        getUser().tenantId == tenantId ||
        getUser().activeTenantId == tenantId
      );
    }
    
    function isTenantAdmin(tenantId) {
      // Check claims first (new system)
      return (request.auth.token.hrx == true) ||
             (request.auth.token.roles != null && 
              tenantId in request.auth.token.roles && 
              request.auth.token.roles[tenantId].role == 'Admin') ||
             // Fallback to legacy system
             (isAssignedToTenant(tenantId) && (
               getUser().role == "HRX" ||
               getUser().securityLevel == "Admin" ||
               getUser().securityLevel == "6" ||
               getUser().securityLevel == "7" ||
               (getUser().tenantIds != null && 
                tenantId in getUser().tenantIds && 
                (getUser().tenantIds[tenantId].securityLevel == "Admin" || 
                 getUser().tenantIds[tenantId].securityLevel == "6" ||
                 getUser().tenantIds[tenantId].securityLevel == "7"))
             ));
    }
    
    function validateTenantSlug() {
      let slug = request.resource.data.slug;
      return slug != null &&
             slug != "" &&
             slug.matches('^[a-z0-9-]+$') &&
             slug.size() >= 3 &&
             slug.size() <= 50 &&
             !slug.matches('^-.*') &&
             !slug.matches('.*-$');
    }
    
    function hasCRMAccess() {
      let user = getUser();
      // Temporarily allow any authenticated user for CRM access (since module is only visible to salespeople)
      return isAuthenticated() ||
             user.securityLevel == "4" || 
             user.securityLevel == "5" || 
             user.securityLevel == "6" || 
             user.securityLevel == "7" ||
             user.crm_sales == true ||
             user.role == "HRX";
    }
    
    function hasRecruiterAccess() {
      let user = getUser();
      return isAuthenticated() &&
             (user.role == "HRX" ||
              user.role == "Recruiter" ||
              user.role == "Recruiting_Manager" ||
              user.securityLevel == "6" ||
              user.securityLevel == "7" ||
              user.recruiter_access == true);
    }
    
    function belongsToSameTenant(targetUserData) {
      let currentUser = getUser();
      
      // Check if both users belong to the same tenant
      return (currentUser.tenantIds != null && targetUserData.tenantIds != null && 
              currentUser.tenantIds is map && targetUserData.tenantIds is map &&
              currentUser.tenantIds.keys().hasAny(targetUserData.tenantIds.keys())) ||
             (currentUser.tenantId != null && targetUserData.tenantId != null && 
              currentUser.tenantId == targetUserData.tenantId) ||
             (currentUser.activeTenantId != null && targetUserData.tenantIds != null &&
              targetUserData.tenantIds is map && currentUser.activeTenantId in targetUserData.tenantIds);
    }
    
    function isHighSecurityLevel() {
      let user = getUser();
      return user.securityLevel == "6" || user.securityLevel == "7";
    }
    
    // SMS-specific helpers
    // Check if user is internal (security level >= 5) for the given tenant
    function isInternal(tenantId) {
      return isHRX() || hasSecurityLevel(tenantId, 5);
    }
    
    // Check if user has at least the specified security level for the tenant
    function hasSecurityLevel(tenantId, minLevel) {
      // HRX always has access
      if (isHRX()) {
        return true;
      }
      
      let user = getUser();
      
      // Check tenant-specific security level first
      if (user.tenantIds != null && 
          tenantId in user.tenantIds && 
          user.tenantIds[tenantId].securityLevel != null) {
        let tenantLevel = user.tenantIds[tenantId].securityLevel;
        // Handle both string and number formats
        let levelNum = tenantLevel is string ? int(tenantLevel) : tenantLevel;
        return levelNum >= minLevel;
      }
      
      // Fallback to root security level
      if (user.securityLevel != null) {
        let levelNum = user.securityLevel is string ? int(user.securityLevel) : user.securityLevel;
        return levelNum >= minLevel;
      }
      
      return false;
    }
  }
}