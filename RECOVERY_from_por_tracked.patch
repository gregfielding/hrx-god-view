diff --git a/firestore.rules b/firestore.rules
index 8099d632..8744727c 100644
--- a/firestore.rules
+++ b/firestore.rules
@@ -145,15 +145,41 @@ service cloud.firestore {
     
     // --- USERS ---
     match /users/{userId} {
+      // Most permissive rule first - allow any authenticated user to read any user document
+      // This is needed for DM functionality and other features
+      allow read: if isAuthenticated() && request.auth.uid != null;
+      
       allow read, write: if isAuthenticated() && request.auth.uid == userId;
       allow read, write: if isHRX();
       allow read: if isAuthenticated() && isAssignedToTenant(resource.data.tenantId);
       allow read: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
       // Allow users to read other users who belong to the same tenant (for salespeople functionality)
       allow read: if isAuthenticated() && hasCRMAccess() && belongsToSameTenant(resource.data);
+
+    // --- USER CONSENTS (Compliance Logging) ---
+    // userConsents/{uid} - SMS consent records for compliance
+    match /userConsents/{uid} {
+      // Users can read their own consent record
+      allow read: if isAuthenticated() && request.auth.uid == uid;
+      // HRX admins can read all consent records (for compliance audits)
+      allow read: if isHRX();
+      // Backend only can write (via Cloud Functions)
+      allow write: if false; // Only backend functions can write
+      
+      // Events subcollection for STOP/HELP logging
+      match /events/{eventId} {
+        // Users can read their own consent events
+        allow read: if isAuthenticated() && request.auth.uid == uid;
+        // HRX admins can read all events (for compliance audits)
+        allow read: if isHRX();
+        // Backend only can write (via Cloud Functions)
+        allow write: if false; // Only backend functions can write
+      }
+    }
       // Allow high-security-level users to update user profiles
       allow write: if isAuthenticated() && isHighSecurityLevel();
-      // Unified Association Service access for salespeople
+      // This allows reading any user document if authenticated (for DM thread creation)
+      // The actual tenant check happens at the thread level
       allow read: if isAuthenticated() && request.auth.uid != null;
       
       // --- USER FOLLOWED COMPANIES ---
@@ -742,6 +768,52 @@ service cloud.firestore {
         allow read: if resource.data.visibility == 'public';
       }
 
+      // --- SLACK COLLECTIONS (Tenant Subcollections) ---
+      // Slack channels - requires security level 5+ for active tenant
+      match /slackChannels/{channelId} {
+        allow read: if isAuthenticated() && 
+                       isAssignedToTenant(tenantId) && 
+                       getActiveTenantId() == tenantId &&
+                       canAccessSlack();
+        // Allow users with security level >= 5 to update watch/mute status
+        allow update: if isAuthenticated() && 
+                         isAssignedToTenant(tenantId) && 
+                         getActiveTenantId() == tenantId &&
+                         canAccessSlack() &&
+                         // Only allow updates to status field - validate it's a valid status
+                         request.resource.data.status != null &&
+                         (request.resource.data.status == 'watching' || 
+                          request.resource.data.status == 'unlinked' || 
+                          request.resource.data.status == 'muted') &&
+                         // Ensure tenantId matches (if it exists in both)
+                         (resource.data.tenantId == null || request.resource.data.tenantId == resource.data.tenantId || request.resource.data.tenantId == tenantId);
+        // Allow admins (security level >= 7) to delete channels
+        allow delete: if isAuthenticated() && 
+                       isAssignedToTenant(tenantId) && 
+                       getActiveTenantId() == tenantId &&
+                       getTenantSecurityLevel() >= 7;
+        // Create is backend-only
+        allow create: if false;
+      }
+
+      // Slack messages - requires security level 5+ for active tenant
+      match /slack_messages/{messageId} {
+        allow read: if isAuthenticated() && 
+                       isAssignedToTenant(tenantId) && 
+                       getActiveTenantId() == tenantId &&
+                       canAccessSlack();
+        allow write: if false; // Only backend writes via Admin SDK
+      }
+
+      // Slack users mapping - requires security level 5+ for active tenant
+      match /slackUsers/{slackUserId} {
+        allow read: if isAuthenticated() && 
+                       isAssignedToTenant(tenantId) && 
+                       getActiveTenantId() == tenantId &&
+                       canAccessSlack();
+        allow write: if false; // Only backend writes via Admin SDK
+      }
+
       // --- JOB POSTINGS (New collection name) ---
       match /job_postings/{postId} {
         allow read, write: if isHRX() || isTenantAdmin(tenantId);
@@ -778,6 +850,263 @@ service cloud.firestore {
         allow read, write: if isHRX() || isTenantAdmin(tenantId);
         allow read, write: if isAssignedToTenant(tenantId) && hasRecruiterAccess();
       }
+      
+      // --- SLACK INTEGRATION (Tenant-scoped) ---
+      match /slackUsers/{slackUserId} {
+        allow read: if isAuthenticated() && 
+          canAccessSlack() && 
+          tenantId == getActiveTenantId();
