{
  "name": "hrx-god-view",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.18.0",
    "@mui/lab": "^5.0.0-alpha.129",
    "@mui/material": "^5.18.0",
    "@mui/system": "^5.18.0",
    "@mui/x-date-pickers": "^8.10.2",
    "@react-google-maps/api": "^2.20.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/papaparse": "^5.3.16",
    "chart.js": "^4.5.0",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.4.0",
    "heic2any": "^0.0.4",
    "html-webpack-plugin": "^5.6.0",
    "http-proxy-middleware": "^3.0.5",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "openai": "^5.12.1",
    "papaparse": "^5.5.3",
    "quill": "^2.0.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.3.8",
    "react-easy-crop": "^5.4.2",
    "react-helmet-async": "^2.0.5",
    "react-markdown": "^10.1.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.6.0",
    "react-scripts": "^5.0.1",
    "recharts": "^2.15.4",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5",
    "yup": "^1.6.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "scripts": {
    "start": "craco start",
    "start:placements": "node scripts/run-local-with-placements-ui.js",
    "start:lenient": "NODE_OPTIONS=--max-old-space-size=4096 DISABLE_ESLINT_PLUGIN=true TSC_COMPILE_ON_ERROR=true craco start",
    "start:safe": "NODE_OPTIONS=--max-old-space-size=8192 DISABLE_ESLINT_PLUGIN=true TSC_COMPILE_ON_ERROR=true SKIP_PREFLIGHT_CHECK=true craco start",
    "build": "CI=false DISABLE_ESLINT_PLUGIN=true craco build",
    "build:lenient": "DISABLE_ESLINT_PLUGIN=true TSC_COMPILE_ON_ERROR=true craco build",
    "build:strict": "craco build",
    "test": "craco test",
    "test:coverage": "craco test --coverage --watchAll=false && node scripts/checkCoverage.js",
    "eject": "react-scripts eject",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,md}'",
    "e2e": "playwright test",
    "seed-roles": "ts-node --project scripts/tsconfig.json scripts/seed-tenant-roles.ts",
    "seed-roles:execute": "ts-node --project scripts/tsconfig.json scripts/seed-tenant-roles.ts --execute",
    "assign-roles": "ts-node --project scripts/tsconfig.json scripts/assign-initial-roles.ts",
    "smoke-test": "ts-node --project scripts/tsconfig.json scripts/smoke-test-phase2.ts",
    "verify-phase2-auth": "ts-node --project scripts/tsconfig.json scripts/verify-phase2-auth.ts",
    "validate:applications": "ts-node --project scripts/tsconfig.json scripts/validateApplicationsInvariants.ts",
    "export:prescreen-interviews": "ts-node --project scripts/tsconfig.json scripts/exportLastWorkerAiPrescreenInterviews.ts",
    "qa:prescreen-review": "ts-node --project scripts/tsconfig.json scripts/reviewPrescreenInterviewBatch.ts",
    "consolidation:dry-run": "ts-node --project scripts/tsconfig.consolidation.json scripts/applicationConsolidationDryRun.ts",
    "consolidation:execute": "ts-node --project scripts/tsconfig.consolidation.json scripts/applicationConsolidationExecute.ts",
    "consolidation:scan-nested": "ts-node --project scripts/tsconfig.consolidation.json scripts/scanNestedJobOrderApplications.ts",
    "check:parity": "ts-node scripts/checkFieldParity.ts",
    "test:mapping": "ts-node scripts/testMapping.ts",
    "test:adapter": "ts-node scripts/testDealStageAdapter.ts",
    "test:i9-extraction": "cd functions && npx ts-node --project tsconfig.scripts.json scripts/testI9Extraction.ts",
    "test:everify-preflight": "cd functions && npx ts-node --project tsconfig.scripts.json scripts/testEverifyI9Preflight.ts",
    "seed-smart-groups": "node scripts/seedSmartGroupsFromApplications.js",
    "build:metros": "node scripts/buildMetroMasterUS.js",
    "i18n:copy": "node -e \"const fs=require('fs'); const path=require('path'); const d=path.join('public','i18n','locales'); fs.mkdirSync(d,{recursive:true}); fs.copyFileSync(path.join('i18n','locales','en.json'), path.join(d,'en.json')); fs.copyFileSync(path.join('i18n','locales','es.json'), path.join(d,'es.json'));\"",
    "i18n:check": "ts-node scripts/i18n/check-i18n.ts",
    "prestart": "npm run i18n:copy",
    "prebuild": "npm run i18n:copy",
    "firebase": "npx firebase",
    "deploy:functions": "npx firebase deploy --only functions",
    "deploy:functions:screening-automation": "npx firebase deploy --only functions:onAssignmentConfirmedScreeningAutomation",
    "deploy:functions:assignment-emails": "npx firebase deploy --only functions:logAssignmentUpdated,functions:logAssignmentCreated,functions:previewAssignmentDetailsEmail",
    "deploy:hosting": "node scripts/hostingPredeploy.js && npm run firebase -- deploy --only hosting"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@playwright/test": "^1.54.2",
    "@types/chart.js": "^2.9.41",
    "@types/jspdf": "^1.3.3",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "dotenv": "^17.2.2",
    "eslint": "^8.44.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "firebase-tools": "^15.11.0",
    "node-fetch": "^2.7.0",
    "prettier": "^2.8.8",
    "ts-node": "^10.9.2"
  },
  "editor.formatOnSave": true,
  "files.autoSave": "onWindowChange"
}
