# Copy into repo-root `.env` (or set in Firebase / GCP). Predeploy: `npm --prefix functions run copy-env`
#
# --- Sandbox (test data) — official API host from SourceDirect V2 docs ---
ACCUSOURCE_ENVIRONMENT=sandbox
ACCUSOURCE_BASE_URL=https://sdapi-sandbox.accusourcedirect.construction
# OAuth (recommended): same stack as URL above. Token: .../oauth/access_token on this host.
SOURCEDIRECT_CLIENT_ID=
SOURCEDIRECT_CLIENT_SECRET=
# Legacy Bearer (omit when using OAuth):
# ACCUSOURCE_API_KEY=
# Optional override only if AccuSource gives a custom token URL (never uscis.gov):
# SOURCEDIRECT_TOKEN_URL=https://sdapi-sandbox.accusourcedirect.construction/oauth/access_token
#
# --- Production (live data) ---
# ACCUSOURCE_ENVIRONMENT=production
# ACCUSOURCE_BASE_URL=https://sdapi.accusourcedirect.com
# SOURCEDIRECT_TOKEN_URL=https://sdapi.accusourcedirect.com/oauth/access_token
