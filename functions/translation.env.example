# Translation Phase 1 — env vars for worker + trigger
# Copy the names below into .env or .env.<projectId> and set values. Do not commit real keys.

# --- Worker: processTranslationJob (HTTP) ---
# OpenAI key; same as other functions (optional fallback: OPENAI_KEY)
OPENAI_API_KEY=

# --- Trigger: onJobPostingWrite + enqueuer ---
# Set to "true" to enable translation; "false" or unset = trigger no-ops
TRANSLATION_ENABLED=false

# Full HTTPS URL of processTranslationJob (get after first deploy)
TRANSLATION_WORKER_URL=

# Service account email Cloud Tasks uses for OIDC (must have Cloud Run Invoker on worker)
TASKS_SERVICE_ACCOUNT_EMAIL=

# Optional; default us-central1
# TASKS_LOCATION=us-central1

# Optional; default translation-es
# TASKS_QUEUE_TRANSLATION=translation-es

# Optional; normal | verbose
# TRANSLATION_LOG_LEVEL=normal
