{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "target": "es2017",
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["scripts/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "lib", "src/**/*.test.ts", "src/**/__tests__/**/*"]
}
