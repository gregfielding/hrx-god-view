# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.DS_Store
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Firebase debug logs
firebase-debug.log
firestore-debug.log
pglite-debug.log
functions/firebase-debug.log
functions/pglite-debug.log

# Firebase Hosting cache noise
.firebase/hosting.*.cache

functions/.env*

functions/.env*

# Service account keys (NEVER commit these!)
service-account-key.json
functions/service-account-key.json
**/service-account-key.json

# PII bulk-import CSVs (Tempworks exports — SSN-last-4, phone, email).
# Uppercase-only on purpose: the legit tracked .csv files under src/data/,
# scripts/, and scripts/data/ are app data, NOT PII; matching `*.csv`
# broadly would hide them. Tempworks ships its exports as `.CSV`.
# NOTE: on macOS (core.ignorecase=true) this pattern matches lowercase
# `.csv` too — already-tracked files are unaffected, but NEW .csv files
# need an explicit exception like the one below.
*.CSV
# Business reference-data snapshots (site directories etc.) — NOT PII.
# Never put worker exports here.
!docs/reference/*.csv

# Claude/Cursor scratch output (logs, query dumps, etc. — never commit)
.scratch/

# Notebook artifacts
*.ipynb

# Local QA cursors (optional; remove from gitignore if you want to commit a team cursor template)
.qa/
.firebase/hosting.*.cache
.claude/
